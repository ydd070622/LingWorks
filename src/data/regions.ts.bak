/** 获取按拼音排序的省份列表 */
export function getSortedProvinces(): string[] {
  return Object.keys(regionData).sort((a, b) => a.localeCompare(b, 'zh'))
}

/** 获取指定省份的城市列表 */
export function getCities(province: string): string[] {
  const data = regionData[province]
  if (!data) return []
  return Object.keys(data.cities).sort((a, b) => a.localeCompare(b, 'zh'))
}

/** 获取指定城市下的区县列表 */
export function getDistricts(province: string, city: string): string[] {
  return regionData[province]?.cities[city] || []
}
